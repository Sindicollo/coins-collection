{
  "extends": "@electron-toolkit/tsconfig/tsconfig.node.json",
  "compilerOptions": {
    "composite": true,
    "moduleResolution": "bundler",
    "paths": {
      "@shared/*": ["./src/shared/*"]
    },
    "outDir": "./out/main",
    "types": ["electron-vite/node", "node"]
  },
  "include": [
    "src/main/**/*.ts",
    "src/preload/**/*.ts",
    "src/shared/**/*.ts",
    "electron.vite.config.ts"
  ]
}
